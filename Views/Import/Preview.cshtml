@using FinanceTracker.Models
@using FinanceTracker.Controllers
@{
    ViewData["Title"] = "Preview Import";
}

@{
    var parsed = (List<ParsedTransaction>)ViewBag.Parsed;
    var accountId = (int)ViewBag.AccountId;
    var categories = (List<Category>)ViewBag.Categories;
    var totalCredits = parsed.Where(p => p.Type == TransactionType.Income).Sum(p => p.Amount);
    var totalDebits = parsed.Where(p => p.Type == TransactionType.Expense).Sum(p => p.Amount);
    var uncCount = parsed.Count(p => p.IsUncategorized);
}

<div style="margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
        <h2 style="font-size:20px;font-weight:700;">Preview: @parsed.Count Transactions Found</h2>
        <div style="font-size:13px;color:var(--text-muted);">Importing into: <strong>@ViewBag.AccountName</strong></div>
    </div>
    <a asp-action="Index" class="btn btn-outline btn-sm">← Re-upload</a>
</div>

@if (ViewBag.UncategorizedWarning != null)
{
    <div style="background:#fef9c3;border:1px solid #fde047;border-radius:12px;padding:14px 18px;margin-bottom:20px;display:flex;gap:10px;">
        <span style="font-size:20px;">⚠️</span>
        <div>
            <div style="font-weight:600;color:#854d0e;">Auto-categorization incomplete</div>
            <div style="font-size:13px;color:#713f12;">@ViewBag.UncategorizedWarning</div>
        </div>
    </div>
}

<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card">
        <div class="stat-icon" style="background:#e0e7ff;">📋</div>
        <div class="stat-info"><div class="stat-label">Total</div><div class="stat-value">@parsed.Count</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;">📈</div>
        <div class="stat-info"><div class="stat-label">Credits</div><div class="stat-value text-income">₹@totalCredits.ToString("N2")</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fee2e2;">📉</div>
        <div class="stat-info"><div class="stat-label">Debits</div><div class="stat-value text-expense">₹@totalDebits.ToString("N2")</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fef9c3;">❓</div>
        <div class="stat-info">
            <div class="stat-label">Uncategorized</div>
            <div class="stat-value" style="color:@(uncCount > 0 ? "#d97706" : "var(--success)");">@uncCount</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Transaction Preview</span>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button type="button" class="btn btn-outline btn-sm" onclick="toggleAll(true)">Select All</button>
            <button type="button" class="btn btn-outline btn-sm" onclick="toggleAll(false)">Deselect All</button>
            @if (uncCount > 0)
            {
                <button type="button" class="btn btn-outline btn-sm" onclick="filterUncategorized()" id="filterBtn">⚠️ Uncategorized Only (@uncCount)</button>
            }
        </div>
    </div>

    <form asp-action="Confirm" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="accountId" value="@accountId" />
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th style="width:40px;"><input type="checkbox" id="selectAll" checked onchange="toggleAll(this.checked)" /></th>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < parsed.Count; i++)
                    {
                        var p = parsed[i];
                        var relevantCats = categories.Where(c => c.Type == p.Type).ToList();
                        var rowBg = p.IsUncategorized ? "background:#fffbeb;" : "";
                        <tr data-unc="@p.IsUncategorized.ToString().ToLower()" style="@rowBg">
                            <td><input type="checkbox" name="rows[@i].Import" value="true" checked class="row-check" /></td>
                            <td>
                                <input type="hidden" name="rows[@i].Date" value="@p.Date.ToString("yyyy-MM-dd")" />
                                <input type="hidden" name="rows[@i].Amount" value="@p.Amount" />
                                <input type="hidden" name="rows[@i].Type" value="@((int)p.Type)" />
                                <span style="font-size:13px;white-space:nowrap;">@p.Date.ToString("dd MMM yyyy")</span>
                            </td>
                            <td>
                                <input type="text" name="rows[@i].Description" value="@p.Description"
                                       class="form-control" style="font-size:13px;padding:6px 10px;min-width:180px;" />
                                <div style="font-size:11px;color:var(--text-muted);margin-top:2px;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@p.FullDetails">@p.FullDetails</div>
                            </td>
                            <td><span class="badge badge-@p.Type.ToString().ToLower()">@p.Type</span></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:6px;">
                                    @if (p.IsUncategorized)
                                    {
                                        <span title="Needs categorization">⚠️</span>
                                    }
                                    <select name="rows[@i].CategoryId" class="form-control"
                                            style="font-size:13px;padding:6px 10px;min-width:160px;@(p.IsUncategorized ? "border-color:#f59e0b;" : "")">
                                        @foreach (var c in relevantCats)
                                        {
                                            if (c.Id == p.CategoryId)
                                            {
                                                <option value="@c.Id" selected>@c.Icon @c.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@c.Id">@c.Icon @c.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </td>
                            <td class="fw-bold @(p.Type == TransactionType.Income ? "text-income" : "text-expense")" style="white-space:nowrap;">
                                @(p.Type == TransactionType.Income ? "+" : "-")₹@p.Amount.ToString("N2")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:20px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
            <div style="font-size:14px;color:var(--text-muted);"><span id="selectedCount">@parsed.Count</span> of @parsed.Count selected</div>
            <button type="submit" class="btn btn-primary" style="padding:12px 32px;"><i class="fas fa-check"></i> Confirm Import</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let showingUncOnly = false;
        function toggleAll(v) {
            document.querySelectorAll('.row-check').forEach(c => c.checked = v);
            document.getElementById('selectAll').checked = v;
            updateCount();
        }
        document.querySelectorAll('.row-check').forEach(c => c.addEventListener('change', updateCount));
        function updateCount() {
            document.getElementById('selectedCount').textContent = document.querySelectorAll('.row-check:checked').length;
        }
        function filterUncategorized() {
            showingUncOnly = !showingUncOnly;
            document.querySelectorAll('tbody tr').forEach(r => {
                r.style.display = (showingUncOnly && r.dataset.unc !== 'true') ? 'none' : '';
            });
            const btn = document.getElementById('filterBtn');
            btn.style.background = showingUncOnly ? '#fef9c3' : '';
            btn.textContent = showingUncOnly ? '✅ Show All' : '⚠️ Uncategorized Only';
        }
    </script>
}
