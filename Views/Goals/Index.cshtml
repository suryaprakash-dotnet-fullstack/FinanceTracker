@model List<FinanceTracker.Models.SavingsGoal>
@{ ViewData["Title"] = "Savings Goals"; }

<div class="grid-2">
<div>
    @foreach (var g in Model)
    {
        var active = g.Status == GoalStatus.Active;
        <div class="card" style="margin-bottom:20px;border-left:4px solid @g.Color;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="font-size:36px;">@g.Icon</div>
                    <div>
                        <div style="font-size:17px;font-weight:700;">@g.Name</div>
                        @if (!string.IsNullOrEmpty(g.Description)) { <div class="text-muted" style="font-size:13px;">@g.Description</div> }
                        @if (g.TargetDate.HasValue) { <div class="text-muted" style="font-size:12px;">🗓️ Target: @g.TargetDate.Value.ToString("MMM dd, yyyy")</div> }
                    </div>
                </div>
                <div style="text-align:right;">
                    <span class="badge @(g.Status == GoalStatus.Completed ? "badge-income" : g.Status == GoalStatus.Active ? "badge-transfer" : "badge-expense")">@g.Status</span>
                    <form asp-action="Delete" asp-route-id="@g.Id" method="post" style="margin-top:6px;" onsubmit="return confirm('Delete this goal?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                    </form>
                </div>
            </div>
            <div class="progress" style="height:12px;margin-bottom:8px;">
                <div class="progress-bar" style="width:@g.Progress%;background:@g.Color;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:14px;">
                <span>@g.CurrentAmount.ToString("C") saved</span>
                <span class="fw-bold">@g.Progress.ToString("F1")%</span>
                <span>@g.TargetAmount.ToString("C") goal</span>
            </div>
            @if (active && g.Status != GoalStatus.Completed)
            {
                <form asp-action="AddFunds" asp-route-id="@g.Id" method="post" style="display:flex;gap:8px;">
                    @Html.AntiForgeryToken()
                    <input type="number" name="amount" step="0.01" min="0" class="form-control" placeholder="Add amount..." style="flex:1;" />
                    <button type="submit" class="btn btn-success btn-sm">Add Funds</button>
                </form>
            }
            @if (g.Status == GoalStatus.Completed) {
                <div style="text-align:center;padding:8px;background:#dcfce7;border-radius:8px;color:#166534;font-weight:600;">🎉 Goal Achieved!</div>
            }
        </div>
    }
    @if (!Model.Any()) {
        <div class="card" style="text-align:center;padding:60px;">
            <div style="font-size:64px;margin-bottom:16px;">🎯</div>
            <h3 style="margin-bottom:8px;">No savings goals yet</h3>
            <p class="text-muted">Create your first savings goal to start tracking your progress!</p>
        </div>
    }
</div>

<div class="card" style="align-self:start;">
    <div class="card-header"><span class="card-title">Create New Goal</span></div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
        <div class="form-group">
            <label class="form-label">Goal Name *</label>
            <input name="Name" class="form-control" placeholder="e.g., Emergency Fund" required />
        </div>
        <div class="form-group">
            <label class="form-label">Description</label>
            <input name="Description" class="form-control" placeholder="What are you saving for?" />
        </div>
        <div class="form-group">
            <label class="form-label">Target Amount *</label>
            <input name="TargetAmount" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" required />
        </div>
        <div class="form-group">
            <label class="form-label">Current Amount</label>
            <input name="CurrentAmount" type="number" step="0.01" min="0" class="form-control" value="0" />
        </div>
        <div class="form-group">
            <label class="form-label">Target Date</label>
            <input name="TargetDate" type="date" class="form-control" />
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Icon</label>
                <select name="Icon" class="form-control">
                    @foreach (var i in new[]{"🎯","🏠","🚗","✈️","💍","📱","🎓","💰","🏖️","🏥","👶","🐕"})
                    {<option value="@i">@i</option>}
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Color</label>
                <input name="Color" type="color" class="form-control" value="#10b981" style="height:42px;padding:4px;" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Create Goal</button>
    </form>
</div>
</div>
