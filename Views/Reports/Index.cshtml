@model FinanceTracker.ViewModels.ReportViewModel
@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="card" style="margin-bottom:20px;">
    <form method="get" style="display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;">
        <div>
            <label class="form-label">From Date</label>
            <input class="form-control" type="date" name="from"
                   value="@Model.StartDate.ToString("yyyy-MM-dd")" />
        </div>

        <div>
            <label class="form-label">To Date</label>
            <input class="form-control" type="date" name="to"
                   value="@Model.EndDate.ToString("yyyy-MM-dd")" />
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="fas fa-chart-bar"></i> Generate Report
        </button>

        <a href="?from=@(new DateTime(DateTime.Now.Year, 1, 1).ToString("yyyy-MM-dd"))&to=@(DateTime.Now.ToString("yyyy-MM-dd"))"
           class="btn btn-outline">
            This Year
        </a>

        <a href="?from=@(new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1).ToString("yyyy-MM-dd"))&to=@(DateTime.Now.ToString("yyyy-MM-dd"))"
           class="btn btn-outline">
            This Month
        </a>

        <a href="?from=@(DateTime.Now.AddMonths(-3).ToString("yyyy-MM-dd"))&to=@(DateTime.Now.ToString("yyyy-MM-dd"))"
           class="btn btn-outline">
            Last 3 Months
        </a>
    </form>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">

    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;">📈</div>
        <div class="stat-info">
            <div class="stat-label">Total Income</div>
            <div class="stat-value text-income">
                @Model.TotalIncome.ToString("C")
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:#fee2e2;">📉</div>
        <div class="stat-info">
            <div class="stat-label">Total Expenses</div>
            <div class="stat-value text-expense">
                @Model.TotalExpenses.ToString("C")
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"
             style="background:@(Model.NetSavings >= 0 ? "#dcfce7" : "#fee2e2");">
            💰
        </div>
        <div class="stat-info">
            <div class="stat-label">Net Savings</div>
            <div class="stat-value"
                 style="color:@(Model.NetSavings >= 0 ? "var(--success)" : "var(--danger)")">
                @Model.NetSavings.ToString("C")
            </div>
        </div>
    </div>

</div>

<div class="grid-2" style="margin-bottom:24px;">

    <div class="card">
        <div class="card-header">
            <span class="card-title">Expense Breakdown</span>
        </div>

        @if (Model.ExpensesByCategory.Any())
        {
            <canvas id="expenseChart" height="220"></canvas>
        }
        else
        {
            <p class="text-muted"
               style="text-align:center;padding:40px;">
                No expense data for this period.
            </p>
        }
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title">Income Sources</span>
        </div>

        @if (Model.IncomeByCategory.Any())
        {
            <canvas id="incomeChart" height="220"></canvas>
        }
        else
        {
            <p class="text-muted"
               style="text-align:center;padding:40px;">
                No income data for this period.
            </p>
        }
    </div>

</div>

@if (Model.MonthlyTrend.Any())
{
    <div class="card" style="margin-bottom:24px;">
        <div class="card-header">
            <span class="card-title">Monthly Trend</span>
        </div>

        <canvas id="trendChart" height="140"></canvas>
    </div>
}

<div class="card">

    <div class="card-header">
        <span class="card-title">
            All Transactions (@Model.Transactions.Count)
        </span>
    </div>

    <div class="table-wrap">

        <table>

            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th>Account</th>
                    <th>Type</th>
                    <th>Amount</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var t in Model.Transactions)
                {
                    <tr>

                        <td class="text-muted">
                            @t.Date.ToString("MMM dd, yyyy")
                        </td>

                        <td>@t.Description</td>

                        <td>
                            @t.Category?.Icon
                            @t.Category?.Name
                        </td>

                        <td>@t.Account?.Name</td>

                        <td>
                            <span class="badge badge-@t.Type.ToString().ToLower()">
                                @t.Type
                            </span>
                        </td>

                        <td class="fw-bold @(t.Type == TransactionType.Income ? "text-income" : t.Type == TransactionType.Expense ? "text-expense" : "")">

                            @(t.Type == TransactionType.Income ? "+" :
                                                    t.Type == TransactionType.Expense ? "-" : "")

                        @t.Amount.ToString("C")

                        </td>

                    </tr>
                                }

            </tbody>

        </table>

    </div>

</div>