@model FinanceTracker.ViewModels.TransactionViewModel
@{ ViewData["Title"] = "Edit Transaction"; }

<div style="max-width:680px;margin:0 auto;">
<div class="card">
    <div class="card-header">
        <span class="card-title">✏️ Edit Transaction</span>
        <a asp-action="Index" class="btn btn-outline btn-sm">← Back</a>
    </div>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <div style="display:flex;gap:10px;margin-bottom:18px;">
            @foreach (var type in Enum.GetValues<TransactionType>())
            {
                var icons = type == TransactionType.Income ? "📈" : type == TransactionType.Expense ? "📉" : "🔄";
                <label style="flex:1;cursor:pointer;">
                    <input type="radio" name="Type" value="@type" @(Model.Type == type ? "checked" : "") style="display:none;" class="type-radio" />
                    <div class="type-btn" data-type="@type" style="padding:14px;border:2px solid var(--border);border-radius:12px;text-align:center;transition:all 0.2s;">
                        <div style="font-size:24px;">@icons</div>
                        <div style="font-weight:600;font-size:14px;margin-top:4px;">@type</div>
                    </div>
                </label>
            }
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Amount *</label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="form-group">
                <label class="form-label">Date *</label>
                <input asp-for="Date" class="form-control" type="date" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Description *</label>
            <input asp-for="Description" class="form-control" />
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Category *</label>
                <select asp-for="CategoryId" class="form-control">
                    @foreach (var c in (List<Category>)ViewBag.CategoriesList)
                    {<option value="@c.Id">@c.Icon @c.Name (@c.Type)</option>}
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Account *</label>
                <select asp-for="AccountId" class="form-control">
                    @foreach (var a in (List<Account>)ViewBag.AccountsList)
                    {<option value="@a.Id">@a.Icon @a.Name</option>}
                </select>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Tags</label>
                <input asp-for="Tags" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Notes</label>
                <input asp-for="Notes" class="form-control" />
            </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px;">
            <i class="fas fa-save"></i> Update Transaction
        </button>
    </form>
</div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.type-radio').forEach(r => r.addEventListener('change', updateTypeButtons));
function updateTypeButtons() {
    document.querySelectorAll('.type-btn').forEach(btn => { btn.style.borderColor='var(--border)'; btn.style.background='white'; });
    const checked = document.querySelector('.type-radio:checked');
    if(checked){
        const btn = checked.nextElementSibling;
        if(checked.value==='Income'){btn.style.borderColor='#10b981';btn.style.background='#dcfce7';}
        else if(checked.value==='Expense'){btn.style.borderColor='#ef4444';btn.style.background='#fee2e2';}
        else{btn.style.borderColor='#6366f1';btn.style.background='#e0e7ff';}
    }
}
updateTypeButtons();
document.querySelectorAll('.type-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{btn.previousElementSibling.checked=true;updateTypeButtons();});
});
</script>
}
