@model List<FinanceTracker.Models.Account>
@{ ViewData["Title"] = "Accounts"; }

<div class="grid-2">
<div>
    @foreach (var a in Model)
    {
        <div class="card" style="margin-bottom:16px;">
            <div style="display:flex;align-items:center;gap:14px;">
                <div style="width:56px;height:56px;border-radius:16px;background:@a.Color;display:flex;align-items:center;justify-content:center;font-size:26px;">@a.Icon</div>
                <div style="flex:1;">
                    <div style="font-size:16px;font-weight:700;">@a.Name</div>
                    <div class="text-muted" style="font-size:13px;">@a.Type @(a.IsActive ? "" : "(Inactive)")</div>
                </div>
                <div style="text-align:right;">
                    <div style="font-size:22px;font-weight:700;color:@(a.Balance >= 0 ? "var(--success)" : "var(--danger)")">@a.Balance.ToString("C")</div>
                    <div class="text-muted" style="font-size:12px;">Initial: @a.InitialBalance.ToString("C")</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                    @if(a.IsActive) {
                        <form asp-action="Delete" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Deactivate account?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-archive"></i></button>
                        </form>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(a.Notes)) { <div class="text-muted" style="font-size:12px;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);">@a.Notes</div> }
        </div>
    }
    @if (!Model.Any()) {
        <div class="card" style="text-align:center;padding:60px;">
            <div style="font-size:64px;margin-bottom:16px;">🏦</div>
            <h3>No accounts yet</h3>
            <p class="text-muted">Add your first financial account to get started!</p>
        </div>
    }
    <div class="card" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:white;padding:20px;text-align:center;">
        <div style="font-size:32px;margin-bottom:8px;">💰</div>
        <div style="font-size:14px;opacity:0.8;">Total Net Worth</div>
        <div style="font-size:32px;font-weight:700;margin-top:4px;">@Model.Where(a => a.IsActive).Sum(a => a.Balance).ToString("C")</div>
    </div>
</div>

<div class="card" style="align-self:start;">
    <div class="card-header"><span class="card-title">Add New Account</span></div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
        <div class="form-group">
            <label class="form-label">Account Name *</label>
            <input name="Name" class="form-control" placeholder="e.g., HDFC Savings" required />
        </div>
        <div class="form-group">
            <label class="form-label">Account Type *</label>
            <select name="Type" class="form-control">
                @foreach (var t in Enum.GetValues<AccountType>())
                {<option value="@t">@t</option>}
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Initial Balance</label>
            <input name="InitialBalance" type="number" step="0.01" class="form-control" value="0" />
        </div>
        <div class="form-group">
            <label class="form-label">Notes</label>
            <input name="Notes" class="form-control" placeholder="Bank name, account number hint..." />
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Icon</label>
                <select name="Icon" class="form-control">
                    @foreach (var i in new[]{"🏦","💳","💰","📱","🏧","💵","📊","🪙"})
                    {<option value="@i">@i</option>}
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Color</label>
                <input name="Color" type="color" class="form-control" value="#6366f1" style="height:42px;padding:4px;" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Add Account</button>
    </form>
</div>
</div>
