@model FinanceTracker.ViewModels.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:#e0e7ff;">💰</div>
        <div class="stat-info">
            <div class="stat-label">Total Balance</div>
            <div class="stat-value">@Model.TotalBalance.ToString("C")</div>
            <div class="stat-sub">Across @Model.Accounts.Count accounts</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;">📈</div>
        <div class="stat-info">
            <div class="stat-label">Monthly Income</div>
            <div class="stat-value text-income">@Model.MonthlyIncome.ToString("C")</div>
            <div class="stat-sub">This month</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fee2e2;">📉</div>
        <div class="stat-info">
            <div class="stat-label">Monthly Expenses</div>
            <div class="stat-value text-expense">@Model.MonthlyExpenses.ToString("C")</div>
            <div class="stat-sub">This month</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fef9c3;">🏦</div>
        <div class="stat-info">
            <div class="stat-label">Net Savings</div>
            <div class="stat-value" style="color:@(Model.MonthlySavings >= 0 ? "var(--success)" : "var(--danger)")">@Model.MonthlySavings.ToString("C")</div>
            <div class="stat-sub">@Model.TransactionCount total transactions</div>
        </div>
    </div>
</div>

<div class="grid-2" style="margin-bottom:24px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title">Income vs Expenses (6 months)</span>
        </div>
        <canvas id="trendChart" height="200"></canvas>
    </div>
    <div class="card">
        <div class="card-header">
            <span class="card-title">Expenses by Category</span>
        </div>
        <canvas id="categoryChart" height="200"></canvas>
    </div>
</div>

<div class="grid-2" style="margin-bottom:24px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title">Recent Transactions</span>
            <a asp-controller="Transactions" asp-action="Index" class="btn btn-outline btn-sm">View All</a>
        </div>
        @if (!Model.RecentTransactions.Any())
        {
            <p class="text-muted" style="text-align:center;padding:20px;">No transactions yet. <a asp-controller="Transactions" asp-action="Create">Add one!</a></p>
        }
        else
        {
            <div class="table-wrap">
            <table>
                <thead><tr><th>Date</th><th>Description</th><th>Category</th><th>Amount</th></tr></thead>
                <tbody>
                @foreach (var t in Model.RecentTransactions)
                {
                    <tr>
                        <td class="text-muted">@t.Date.ToString("MMM dd")</td>
                        <td>@t.Description</td>
                        <td><span style="font-size:16px;">@t.Category?.Icon</span> @t.Category?.Name</td>
                        <td class="fw-bold @(t.Type == TransactionType.Income ? "text-income" : t.Type == TransactionType.Expense ? "text-expense" : "")">
                            @(t.Type == TransactionType.Income ? "+" : t.Type == TransactionType.Expense ? "-" : "")@t.Amount.ToString("C")
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        }
    </div>
    <div class="card">
        <div class="card-header">
            <span class="card-title">My Accounts</span>
            <a asp-controller="Accounts" asp-action="Create" class="btn btn-outline btn-sm"><i class="fas fa-plus"></i> New</a>
        </div>
        @foreach (var acc in Model.Accounts)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);">
                <div style="width:42px;height:42px;border-radius:12px;background:@acc.Color;display:flex;align-items:center;justify-content:center;font-size:20px;">@acc.Icon</div>
                <div style="flex:1;">
                    <div style="font-weight:600;font-size:14px;">@acc.Name</div>
                    <div class="text-muted" style="font-size:12px;">@acc.Type</div>
                </div>
                <div class="fw-bold" style="color:@(acc.Balance >= 0 ? "var(--success)" : "var(--danger)")">@acc.Balance.ToString("C")</div>
            </div>
        }
        @if (!Model.Accounts.Any()) { <p class="text-muted" style="text-align:center;padding:20px;">No accounts yet.</p> }
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <span class="card-title">Budget Overview</span>
            <a asp-controller="Budgets" asp-action="Index" class="btn btn-outline btn-sm">Manage</a>
        </div>
        @foreach (var b in Model.ActiveBudgets.Take(5))
        {
            var pct = Math.Min((double)b.PercentUsed, 100);
            var color = pct >= 90 ? "var(--danger)" : pct >= 70 ? "var(--warning)" : "var(--success)";
            <div style="margin-bottom:16px;">
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;">
                    <span>@b.Category?.Icon @b.Name</span>
                    <span>@b.Spent.ToString("C") / @b.Amount.ToString("C")</span>
                </div>
                <div class="progress"><div class="progress-bar" style="width:@pct%;background:@color;"></div></div>
            </div>
        }
        @if (!Model.ActiveBudgets.Any()) { <p class="text-muted" style="text-align:center;padding:20px;">No budgets for this month.</p> }
    </div>
    <div class="card">
        <div class="card-header">
            <span class="card-title">Savings Goals</span>
            <a asp-controller="Goals" asp-action="Index" class="btn btn-outline btn-sm">Manage</a>
        </div>
        @foreach (var g in Model.ActiveGoals)
        {
            <div style="margin-bottom:16px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                    <span style="font-size:14px;font-weight:600;">@g.Icon @g.Name</span>
                    <span style="font-size:12px;color:var(--text-muted);">@g.Progress.ToString("F0")%</span>
                </div>
                <div class="progress">
                    <div class="progress-bar" style="width:@g.Progress%;background:@g.Color;"></div>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);margin-top:4px;">
                    <span>@g.CurrentAmount.ToString("C")</span><span>@g.TargetAmount.ToString("C")</span>
                </div>
            </div>
        }
        @if (!Model.ActiveGoals.Any()) { <p class="text-muted" style="text-align:center;padding:20px;">No savings goals yet.</p> }
    </div>
</div>

@section Scripts {
<script>
const months = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last6MonthsData.Select(m => m.Month)));
const income = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last6MonthsData.Select(m => m.Income)));
const expenses = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last6MonthsData.Select(m => m.Expenses)));

new Chart(document.getElementById('trendChart'), {
    type: 'bar',
    data: {
        labels: months,
        datasets: [
            { label: 'Income', data: income, backgroundColor: '#10b98133', borderColor: '#10b981', borderWidth: 2 },
            { label: 'Expenses', data: expenses, backgroundColor: '#ef444433', borderColor: '#ef4444', borderWidth: 2 }
        ]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } }, scales: { y: { beginAtZero: true } } }
});

const catLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExpensesByCategory.Keys.ToList()));
const catData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExpensesByCategory.Values.ToList()));
const catColors = ['#6366f1','#10b981','#f59e0b','#ef4444','#06b6d4','#ec4899','#8b5cf6','#f97316'];

if(catLabels.length > 0) {
    new Chart(document.getElementById('categoryChart'), {
        type: 'doughnut',
        data: { labels: catLabels, datasets: [{ data: catData, backgroundColor: catColors, borderWidth: 0 }] },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });
} else {
    document.getElementById('categoryChart').parentElement.innerHTML += '<p style="text-align:center;color:var(--text-muted);padding:40px;">No expense data yet</p>';
    document.getElementById('categoryChart').remove();
}
</script>
}
