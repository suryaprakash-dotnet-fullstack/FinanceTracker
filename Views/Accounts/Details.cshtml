@model FinanceTracker.Models.Account
@{ ViewData["Title"] = Model.Name; }

<div style="margin-bottom:24px;">
    <a asp-action="Index" class="btn btn-outline btn-sm">← Back to Accounts</a>
</div>

<div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">
    <div style="width:72px;height:72px;border-radius:20px;background:@Model.Color;display:flex;align-items:center;justify-content:center;font-size:32px;">@Model.Icon</div>
    <div>
        <h2 style="font-size:24px;font-weight:700;">@Model.Name</h2>
        <div class="text-muted">@Model.Type</div>
    </div>
    <div style="margin-left:auto;text-align:right;">
        <div class="text-muted" style="font-size:13px;">Current Balance</div>
        <div style="font-size:32px;font-weight:700;color:@(Model.Balance >= 0 ? "var(--success)" : "var(--danger)")">@Model.Balance.ToString("C")</div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Recent Transactions</span>
        <a asp-controller="Transactions" asp-action="Index" asp-route-accountId="@Model.Id" class="btn btn-outline btn-sm">View All</a>
    </div>
    <div class="table-wrap">
    <table>
        <thead><tr><th>Date</th><th>Description</th><th>Category</th><th>Type</th><th>Amount</th></tr></thead>
        <tbody>
        @foreach (var t in (List<Transaction>)ViewBag.Transactions)
        {
            <tr>
                <td class="text-muted">@t.Date.ToString("MMM dd, yyyy")</td>
                <td>@t.Description</td>
                <td>@t.Category?.Icon @t.Category?.Name</td>
                <td><span class="badge badge-@t.Type.ToString().ToLower()">@t.Type</span></td>
                <td class="fw-bold @(t.Type == TransactionType.Income ? "text-income" : t.Type == TransactionType.Expense ? "text-expense" : "")">
                    @(t.Type == TransactionType.Income ? "+" : "-")@t.Amount.ToString("C")
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
</div>
